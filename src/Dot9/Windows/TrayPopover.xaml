<Window x:Class="Dot9.Windows.TrayPopover"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="280"
        SizeToContent="Height"
        Topmost="True"
        Deactivated="OnDeactivated"
        KeyDown="OnKeyDown">

    <Border Background="#FF1D1B18"
            BorderBrush="#1FFFF0D2"
            BorderThickness="1"
            CornerRadius="12"
            Padding="0,8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>

            <!-- SYSTEM TRAY eyebrow -->
            <TextBlock Text="SYSTEM TRAY"
                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                       FontSize="10"
                       Foreground="#FF5A554C"
                       Margin="14,6,14,10" />

            <!-- Overlay toggle row -->
            <Grid Margin="14,0,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Overlay" FontSize="13" FontWeight="Medium"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="TrayHotkeyChip"
                           Grid.Column="1"
                           FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                           FontSize="11"
                           Foreground="#FF5A554C"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <CheckBox x:Name="TrayOverlayToggle"
                          Grid.Column="2"
                          VerticalAlignment="Center"
                          Checked="TrayOverlayChecked"
                          Unchecked="TrayOverlayUnchecked" />
            </Grid>

            <!-- Divider -->
            <Border Height="1" Background="#0FFFF0D2" Margin="0,4,0,8" />

            <!-- QUICK PRESET eyebrow -->
            <TextBlock Text="QUICK PRESET"
                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                       FontSize="10"
                       Foreground="#FF5A554C"
                       Margin="14,0,14,8" />

            <!-- Preset rows (populated from code-behind) -->
            <StackPanel x:Name="PresetRows" Margin="14,0,14,0" />

            <!-- Divider -->
            <Border Height="1" Background="#0FFFF0D2" Margin="0,8,0,8" />

            <!-- Actions -->
            <Button Content="Open settings…"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="14,8"
                    FontSize="13"
                    Click="OpenSettings" />

            <Button Content="Emergency off (F9)"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="14,8"
                    FontSize="13"
                    Foreground="#FFD88A7A"
                    Click="TrayEmergencyOff" />

        </StackPanel>
    </Border>
</Window>
