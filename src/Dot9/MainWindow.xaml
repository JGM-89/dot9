<Window x:Class="Dot9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dot9"
        xmlns:controls="clr-namespace:Dot9.Controls"
        Title="dot[9]"
        Width="1180" Height="820"
        MinWidth="980" MinHeight="720"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220" />
            <!-- Content area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="14,20,14,16">

                <!-- Wordmark at top -->
                <controls:WordmarkControl DockPanel.Dock="Top" Margin="0,0,0,28" />

                <!-- "Watch intro" at bottom -->
                <Button DockPanel.Dock="Bottom"
                        x:Name="ReplayWelcomeBtn"
                        Content="↻  Watch intro"
                        Style="{StaticResource NavButton}"
                        HorizontalAlignment="Stretch"
                        Click="ReplayWelcome"
                        Margin="0,4,0,0" />

                <!-- Nav items -->
                <StackPanel>
                    <Button x:Name="NavPresets"
                            Style="{StaticResource NavButtonActive}"
                            HorizontalAlignment="Stretch"
                            Click="ShowPresets"
                            Margin="0,0,0,2">
                        <TextBlock>▦  Presets</TextBlock>
                    </Button>
                    <Button x:Name="NavTune"
                            Style="{StaticResource NavButton}"
                            HorizontalAlignment="Stretch"
                            Click="ShowTune"
                            Margin="0,0,0,2">
                        <TextBlock>◉  Tune</TextBlock>
                    </Button>
                    <Button x:Name="NavHotkeys"
                            Style="{StaticResource NavButton}"
                            HorizontalAlignment="Stretch"
                            Click="ShowHotkeys"
                            Margin="0,0,0,2">
                        <TextBlock>⌘  Hotkeys</TextBlock>
                    </Button>
                    <Button x:Name="NavSafety"
                            Style="{StaticResource NavButton}"
                            HorizontalAlignment="Stretch"
                            Click="ShowSafety"
                            Margin="0,0,0,2">
                        <TextBlock>♡  Safety</TextBlock>
                    </Button>
                    <Button x:Name="NavAbout"
                            Style="{StaticResource NavButton}"
                            HorizontalAlignment="Stretch"
                            Click="ShowAbout">
                        <TextBlock>ⓘ  About</TextBlock>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             CONTENT COLUMN (TopBar + Views + Footer)
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- TopBar -->
                <RowDefinition Height="Auto" />
                <!-- Active view -->
                <RowDefinition Height="*" />
                <!-- Footer -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── TopBar ── -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
                <DockPanel>
                    <!-- Right side: action buttons -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="ToggleOverlayBtn"
                                Content="Turn overlay on"
                                Style="{StaticResource PrimaryButton}"
                                Click="ToggleOverlay"
                                Margin="0,0,8,0" />
                        <Button x:Name="TrayPopoverBtn"
                                Content="▴"
                                Padding="10,9"
                                Click="OpenTrayPopover" />
                    </StackPanel>

                    <!-- Left side: status indicator -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot"
                                 Width="8" Height="8"
                                 Fill="{StaticResource InkDimBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0" />
                        <StackPanel>
                            <TextBlock x:Name="OverlayStatusLabel"
                                       Text="Overlay off"
                                       FontSize="13"
                                       FontWeight="Medium" />
                            <TextBlock x:Name="HotkeySummaryLabel"
                                       Text=""
                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas, Courier New"
                                       FontSize="11"
                                       Foreground="{StaticResource InkDimBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Views ── -->
            <Grid Grid.Row="1" Margin="20">

                <!-- ─── TUNE VIEW ─── -->
                <Grid x:Name="TuneView" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <!-- Left column: preview + edge dots -->
                    <ScrollViewer Grid.Column="0" Margin="0,0,14,0">
                        <StackPanel>

                            <!-- Live preview card -->
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="340" />
                                    </Grid.RowDefinitions>

                                    <!-- Preview header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="LIVE PREVIEW"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas, Courier New"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource InkDimBrush}"
                                                   VerticalAlignment="Center" />
                                        <!-- Right side: reset + backdrop picker -->
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button x:Name="ResetToDefaultsBtn"
                                                Content="Reset to defaults"
                                                Padding="10,6"
                                                FontSize="11"
                                                Margin="0,0,8,0"
                                                Click="ResetToDefaults_Click" />
                                        <!-- Backdrop segmented picker -->
                                        <Border Style="{StaticResource SegmentedContainer}">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="BackdropScene"
                                                             GroupName="BackdropGroup"
                                                             Content="Scene"
                                                             Style="{StaticResource SegmentedOption}"
                                                             IsChecked="True"
                                                             Checked="BackdropSceneChecked" />
                                                <RadioButton x:Name="BackdropBlack"
                                                             GroupName="BackdropGroup"
                                                             Content="Black"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="BackdropBlackChecked" />
                                                <RadioButton x:Name="BackdropChecker"
                                                             GroupName="BackdropGroup"
                                                             Content="Checker"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="BackdropCheckerChecked" />
                                            </StackPanel>
                                        </Border>
                                        </StackPanel>
                                    </Grid>

                                    <local:PreviewSurface x:Name="HomePreview" Grid.Row="1" />
                                </Grid>
                            </Border>

                            <!-- Edge dots section -->
                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <!-- Section header -->
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Edge dots"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <CheckBox x:Name="DotsEnabledCheck"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  IsChecked="True"
                                                  Checked="DotsEnabledChanged"
                                                  Unchecked="DotsEnabledChanged" />
                                    </Grid>

                                    <!-- Body (dims when disabled) -->
                                    <StackPanel x:Name="DotsBody">
                                        <!-- Opacity -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Opacity" FontSize="13" />
                                            <TextBlock x:Name="OpacityVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100"
                                                Margin="0,0,0,14" ValueChanged="OpacityChanged" />

                                        <!-- Size -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Size" FontSize="13" />
                                            <TextBlock x:Name="SizeVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="SizeSlider" Minimum="4" Maximum="28"
                                                Margin="0,0,0,14" ValueChanged="DotSizeChanged" />

                                        <!-- Edge distance -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Edge distance" FontSize="13" />
                                            <TextBlock x:Name="DistanceVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="DistanceSlider" Minimum="8" Maximum="120"
                                                Margin="0,0,0,14" ValueChanged="DistanceChanged" />

                                        <!-- Dots per edge -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Dots per edge" FontSize="13" />
                                            <TextBlock x:Name="DotsPerEdgeVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="DotsPerEdgeSlider" Minimum="3" Maximum="24"
                                                Margin="0,0,0,16" ValueChanged="DotsPerEdgeChanged" />

                                        <!-- Edges + Shape row -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Edges" FontSize="12"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           Margin="0,0,0,6" />
                                                <Border Style="{StaticResource SegmentedContainer}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <RadioButton x:Name="EdgesLR"
                                                                     GroupName="EdgesGroup" Content="L+R"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="EdgesLRChecked" />
                                                        <RadioButton x:Name="EdgesTB"
                                                                     GroupName="EdgesGroup" Content="T+B"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="EdgesTBChecked" />
                                                        <RadioButton x:Name="EdgesAll"
                                                                     GroupName="EdgesGroup" Content="All"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="EdgesAllChecked" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Shape" FontSize="12"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           Margin="0,0,0,6" />
                                                <Border Style="{StaticResource SegmentedContainer}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <RadioButton x:Name="ShapeDot"
                                                                     GroupName="ShapeGroup" Content="Dot"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="ShapeDotChecked" />
                                                        <RadioButton x:Name="ShapeRing"
                                                                     GroupName="ShapeGroup" Content="Ring"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="ShapeRingChecked" />
                                                        <RadioButton x:Name="ShapeSoft"
                                                                     GroupName="ShapeGroup" Content="Soft"
                                                                     Style="{StaticResource SegmentedOption}"
                                                                     Checked="ShapeSoftChecked" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Colour swatches -->
                                        <TextBlock Text="Colour" FontSize="12"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,0,0,8" />
                                        <controls:SwatchRow x:Name="DotSwatches"
                                                            SelectedColorChanged="DotColorSwatchChanged" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right column: Centre + Horizon + Vignette + Monitor -->
                    <ScrollViewer Grid.Column="1">
                        <StackPanel>

                            <!-- Centre point -->
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Centre point"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <CheckBox x:Name="CentreAnchorCheck"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="CentreAnchorChanged"
                                                  Unchecked="CentreAnchorChanged" />
                                    </Grid>
                                    <StackPanel x:Name="CentreBody">
                                        <!-- Opacity -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Opacity" FontSize="13" />
                                            <TextBlock x:Name="CentreOpacityVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="CentreOpacitySlider" Minimum="0" Maximum="100"
                                                Margin="0,0,0,14" ValueChanged="CentreOpacityChanged" />
                                        <!-- Size -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Size" FontSize="13" />
                                            <TextBlock x:Name="CentreSizeVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="CentreSizeSlider" Minimum="4" Maximum="32"
                                                Margin="0,0,0,14" ValueChanged="CentreSizeChanged" />
                                        <!-- Shape -->
                                        <TextBlock Text="Shape" FontSize="12"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <Border Style="{StaticResource SegmentedContainer}" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="CentreRing"
                                                             GroupName="CentreShapeGroup" Content="Ring"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="CentreShapeRingChecked" />
                                                <RadioButton x:Name="CentreDot"
                                                             GroupName="CentreShapeGroup" Content="Dot"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="CentreShapeDotChecked" />
                                                <RadioButton x:Name="CentreCross"
                                                             GroupName="CentreShapeGroup" Content="Cross"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="CentreShapeCrossChecked" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Horizon line -->
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Horizon line"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <CheckBox x:Name="HorizonCheck"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="HorizonChanged"
                                                  Unchecked="HorizonChanged" />
                                    </Grid>
                                    <StackPanel x:Name="HorizonBody">
                                        <!-- Opacity -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Opacity" FontSize="13" />
                                            <TextBlock x:Name="HorizonOpacityVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="HorizonOpacitySlider" Minimum="0" Maximum="100"
                                                Margin="0,0,0,14" ValueChanged="HorizonOpacityChanged" />
                                        <!-- Position -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Position" FontSize="13" />
                                            <TextBlock x:Name="HorizonPositionVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="HorizonPositionSlider" Minimum="20" Maximum="80"
                                                Margin="0,0,0,14" ValueChanged="HorizonPositionChanged" />
                                        <!-- Width -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Width" FontSize="13" />
                                            <TextBlock x:Name="HorizonWidthVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="HorizonWidthSlider" Minimum="16" Maximum="90"
                                                Margin="0,0,0,14" ValueChanged="HorizonWidthChanged" />
                                        <!-- Style -->
                                        <TextBlock Text="Style" FontSize="12"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <Border Style="{StaticResource SegmentedContainer}" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="HorizonFull"
                                                             GroupName="HorizonStyleGroup" Content="Full"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="HorizonStyleFullChecked" />
                                                <RadioButton x:Name="HorizonSplit"
                                                             GroupName="HorizonStyleGroup" Content="Split"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="HorizonStyleSplitChecked" />
                                                <RadioButton x:Name="HorizonTicks"
                                                             GroupName="HorizonStyleGroup" Content="Ticks"
                                                             Style="{StaticResource SegmentedOption}"
                                                             Checked="HorizonStyleTicksChecked" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Gentle vignette -->
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Gentle vignette"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <CheckBox x:Name="VignetteCheck"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="VignetteChanged"
                                                  Unchecked="VignetteChanged" />
                                    </Grid>
                                    <StackPanel x:Name="VignetteBody">
                                        <!-- Opacity -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Opacity" FontSize="13" />
                                            <TextBlock x:Name="VignetteOpacityVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="VignetteOpacitySlider" Minimum="0" Maximum="100"
                                                Margin="0,0,0,14" ValueChanged="VignetteOpacityChanged" />
                                        <!-- Radius -->
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Radius" FontSize="13" />
                                            <TextBlock x:Name="VignetteRadiusVal" HorizontalAlignment="Right"
                                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                       FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        </Grid>
                                        <Slider x:Name="VignetteRadiusSlider" Minimum="20" Maximum="95"
                                                Margin="0,0,0,0" ValueChanged="VignetteRadiusChanged" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Monitor -->
                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="Monitor"
                                               FontSize="14" FontWeight="SemiBold"
                                               Margin="0,0,0,12" />
                                    <ComboBox x:Name="MonitorCombo"
                                              SelectedValuePath="Id"
                                              SelectionChanged="MonitorChanged" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>

                <!-- ─── PRESETS VIEW ─── -->
                <ScrollViewer x:Name="PresetsView">
                    <StackPanel>
                        <TextBlock Text="Friendly presets"
                                   FontSize="20" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Conservative starting points. Tune from these slowly — comfort triggers vary widely between players."
                                   FontSize="13"
                                   Foreground="{StaticResource InkMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <UniformGrid x:Name="PresetGrid" Columns="2" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ─── HOTKEYS VIEW ─── -->
                <ScrollViewer x:Name="HotkeysView" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   FontSize="20" FontWeight="SemiBold"
                                   Margin="0,0,0,20" />
                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="200" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Toggle overlay"
                                                   FontSize="13" FontWeight="Medium" />
                                        <TextBlock Text="Click the button, then press your shortcut"
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkDimBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            x:Name="ToggleHotkeyBtn"
                                            FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                            FontSize="12"
                                            Padding="10,8"
                                            Click="StartToggleHotkeyCapture" />
                                </Grid>

                                <!-- Divider -->
                                <Border Grid.Row="1"
                                        Height="1"
                                        Background="{StaticResource BorderBrush}"
                                        Margin="0,0,0,14" />

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="200" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Emergency off"
                                                   FontSize="13" FontWeight="Medium" />
                                        <TextBlock Text="Click the button, then press your shortcut"
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkDimBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            x:Name="EmergencyHotkeyBtn"
                                            FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                            FontSize="12"
                                            Padding="10,8"
                                            Click="StartEmergencyHotkeyCapture" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Warning notice (shown when hotkeys conflict) -->
                        <Border x:Name="HotkeyWarningBorder"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,10"
                                Visibility="Collapsed">
                            <TextBlock x:Name="HotkeyWarningText"
                                       Text=""
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ─── SAFETY VIEW ─── -->
                <ScrollViewer x:Name="SafetyView" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Safety"
                                   FontSize="20" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Read before using the overlay."
                                   FontSize="13"
                                   Foreground="{StaticResource InkMutedBrush}"
                                   Margin="0,0,0,20" />

                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="May help — does not treat"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Dot[9] is an experimental comfort tool. It does not cure, prevent, diagnose, or treat motion sickness, vertigo, migraine, vestibular disorders, or any medical condition."
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Listen to your body"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Stop playing if you feel strong nausea, dizziness, headache, or disorientation. Use F9 to disable the overlay instantly."
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Avoid intensity"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="High contrast and rapid animation can increase discomfort. Start with the Gentle preset and tune slowly from there."
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Comfort triggers vary"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Rotation, bobbing, acceleration, FOV, camera shake, and peripheral motion all affect different players differently. Presets are starting points, not answers."
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ─── ABOUT VIEW ─── -->
                <ScrollViewer x:Name="AboutView" Visibility="Collapsed">
                    <StackPanel>

                        <!-- Card 1: product info -->
                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <controls:WordmarkControl Margin="0,0,0,16" />

                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,0,0,10"
                                           Text="dot[9] is a small comfort tool for motion-heavy games. It adds subtle visual anchors over your screen: stable dots, a centre point, a horizon line, and a gentle vignette." />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,0,0,10"
                                           Text="Game-related motion discomfort is often linked to sensory conflict: your eyes see fast camera movement while your body feels still. dot[9] uses stable, screen-fixed anchors as a quiet reference frame." />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,0,0,20"
                                           Text="An independent fan-made comfort prototype. Not a medical device. Settings stay local — no telemetry." />

                                <!-- Metadata grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="VERSION" FontSize="11" Foreground="{StaticResource InkDimBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" Margin="0,0,0,2" />
                                        <TextBlock Text="1.0.0" FontSize="12" Foreground="{StaticResource InkMutedBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="LICENSE" FontSize="11" Foreground="{StaticResource InkDimBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" Margin="0,0,0,2" />
                                        <TextBlock Text="All rights reserved" FontSize="12" Foreground="{StaticResource InkMutedBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <TextBlock Text="STACK" FontSize="11" Foreground="{StaticResource InkDimBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" Margin="0,0,0,2" />
                                        <TextBlock Text="WPF · .NET 10" FontSize="12" Foreground="{StaticResource InkMutedBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1">
                                        <TextBlock Text="TELEMETRY" FontSize="11" Foreground="{StaticResource InkDimBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" Margin="0,0,0,2" />
                                        <TextBlock Text="None" FontSize="12" Foreground="{StaticResource InkMutedBrush}"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: taglines -->
                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="WORDS WE USE"
                                           FontSize="11" FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                           Foreground="{StaticResource InkDimBrush}"
                                           Margin="0,0,0,16" />
                                <TextBlock Text="Give your eyes somewhere still to land."
                                           FontSize="15" FontWeight="Medium" Margin="0,0,0,10" />
                                <TextBlock Text="A steadier way to play."
                                           FontSize="15" FontWeight="Medium" Margin="0,0,0,10" />
                                <TextBlock Text="Visual anchors for motion-heavy games."
                                           FontSize="15" FontWeight="Medium" Margin="0,0,0,10" />
                                <TextBlock Text="Stay grounded in fast-moving games."
                                           FontSize="15" FontWeight="Medium" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- ── Footer ── -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="An independent fan-made comfort prototype. Not a medical device."
                               FontSize="11"
                               Foreground="{StaticResource InkDimBrush}" />
                    <TextBlock Margin="8,0,0,0" FontSize="11">
                        <Hyperlink NavigateUri="about:safety" RequestNavigate="FooterSafetyNavigate"
                                   Foreground="{StaticResource AccentBrush}">
                            Safety →
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>
