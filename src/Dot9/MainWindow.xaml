<Window x:Class="Dot9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dot9"
        Title="Dot[9]"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="660"
        Background="{StaticResource CharcoalBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0E1114" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Dot[9]" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock Text="Give your eyes somewhere still to land." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,4,0,28" />
                    <Button Content="Home" Click="ShowHome" Margin="0,0,0,8" />
                    <Button Content="Presets" Click="ShowPresets" Margin="0,0,0,8" />
                    <Button Content="Dots" Click="ShowDots" Margin="0,0,0,8" />
                    <Button Content="Safety" Click="ShowSafety" Margin="0,0,0,8" />
                    <Button Content="About" Click="ShowAbout" Margin="0,0,0,8" />
                </StackPanel>
                <Border DockPanel.Dock="Bottom" Style="{StaticResource PanelCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Hotkeys" FontWeight="SemiBold" />
                        <TextBlock Text="Ctrl+Alt+D or F8 toggles overlay" Foreground="{StaticResource MutedInkBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="Ctrl+Alt+Backspace or F9 emergency off" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
        <Grid Grid.Column="1" Margin="28">
            <Grid x:Name="HomeView">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="340" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,22,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Live preview" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Stable Anchor MVP" Foreground="#101417" Background="{StaticResource AccentBrush}" Padding="8,4" Margin="12,0,0,0" />
                        </StackPanel>
                        <local:PreviewSurface x:Name="HomePreview" Grid.Row="1" Margin="0,24,0,0" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Overlay" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock x:Name="OverlayStatusText" Text="Off" FontSize="42" FontWeight="SemiBold" Margin="0,10,0,0" />
                            <TextBlock x:Name="PresetModeText" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                            <Button x:Name="ToggleOverlayButton" Content="Turn overlay on" Style="{StaticResource PrimaryButton}" Click="ToggleOverlay" Margin="0,18,0,0" />
                            <Button Content="Emergency off" Click="EmergencyOff" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCard}">
                        <StackPanel>
                            <TextBlock Text="Quick controls" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Dot opacity" Margin="0,18,0,6" />
                            <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" ValueChanged="OpacityChanged" />
                            <TextBlock Text="Dot size" Margin="0,16,0,6" />
                            <Slider x:Name="SizeSlider" Minimum="4" Maximum="28" ValueChanged="DotSizeChanged" />
                            <TextBlock Text="Distance from screen edge" Margin="0,16,0,6" />
                            <Slider x:Name="DistanceSlider" Minimum="8" Maximum="120" ValueChanged="DistanceChanged" />
                            <CheckBox x:Name="CentreAnchorCheck" Content="Show centre point" Foreground="{StaticResource InkBrush}" Margin="0,16,0,0" Checked="CentreAnchorChanged" Unchecked="CentreAnchorChanged" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource PanelCard}" Padding="14" Margin="0,20,0,0">
                    <TextBlock Text="Dot[9] is an experimental comfort tool, not a medical treatment. Stop playing if nausea, dizziness, headache, or disorientation gets strong." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                </Border>
            </Grid>
            <ScrollViewer x:Name="PresetsView" Visibility="Collapsed"><UniformGrid x:Name="PresetGrid" Columns="2" /></ScrollViewer>
            <Grid x:Name="DotsView" Visibility="Collapsed">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="380" /></Grid.ColumnDefinitions>
                <Border Style="{StaticResource PanelCard}" Margin="0,0,22,0"><local:PreviewSurface x:Name="DotsPreview" /></Border>
                <Border Grid.Column="1" Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <TextBlock Text="Dots" FontSize="24" FontWeight="SemiBold" />
                        <CheckBox x:Name="DotsEnabledCheck" Content="Show edge dots" Foreground="{StaticResource InkBrush}" Margin="0,18,0,12" Checked="DotsEnabledChanged" Unchecked="DotsEnabledChanged" />
                        <TextBlock Text="Shape" /><ComboBox x:Name="ShapeCombo" SelectionChanged="ShapeChanged" Margin="0,6,0,14" />
                        <TextBlock Text="Edges" /><ComboBox x:Name="EdgesCombo" SelectionChanged="EdgesChanged" Margin="0,6,0,14" />
                        <TextBlock Text="Colour palette" /><ComboBox x:Name="ColorCombo" SelectionChanged="ColorChanged" Margin="0,6,0,14" />
                        <TextBlock Text="Dots per edge" /><Slider x:Name="DotsPerEdgeSlider" Minimum="3" Maximum="24" ValueChanged="DotsPerEdgeChanged" />
                        <CheckBox x:Name="DotsCentreAnchorCheck" Content="Show centre point" Foreground="{StaticResource InkBrush}" Margin="0,16,0,0" Checked="CentreAnchorChanged" Unchecked="CentreAnchorChanged" />
                        <Button Content="Reset to Gentle" Click="ResetGentle" Margin="0,18,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
            <ScrollViewer x:Name="SafetyView" Visibility="Collapsed"><StackPanel><TextBlock Text="Safety" FontSize="30" FontWeight="SemiBold" /><Border Style="{StaticResource PanelCard}" Margin="0,18,0,0"><StackPanel><TextBlock Text="Use gentle settings first" FontSize="20" FontWeight="SemiBold" /><TextBlock Text="Start with low-opacity stable dots. Make changes slowly and avoid flashing, rapid pulsing, or high contrast." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel></Border><Border Style="{StaticResource PanelCard}" Margin="0,14,0,0"><StackPanel><TextBlock Text="Not a medical treatment" FontSize="20" FontWeight="SemiBold" /><TextBlock Text="Dot[9] may help some players find a steadier visual reference, but it does not cure, prevent, diagnose, or treat motion sickness, vertigo, migraine, or vestibular conditions." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel></Border></StackPanel></ScrollViewer>
            <ScrollViewer x:Name="AboutView" Visibility="Collapsed"><StackPanel><TextBlock Text="About Dot[9]" FontSize="30" FontWeight="SemiBold" /><Border Style="{StaticResource PanelCard}" Margin="0,18,0,0"><StackPanel><TextBlock Text="Version 0.1.0" Foreground="{StaticResource MutedInkBrush}" /><TextBlock Text="Dot[9] is a small comfort tool for motion-heavy games. It adds subtle visual anchors over your screen, giving your eyes somewhere still to land." TextWrapping="Wrap" Margin="0,14,0,0" /><TextBlock Text="Dot[9] is a fan-made gift prototype inspired by a love of thoughtful gaming tools. It is not an official Day[9]TV product unless adopted or approved by Day[9]." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,14,0,0" /><TextBlock Text="Privacy: settings stay local. The MVP collects no telemetry and sends no game, health, profile, usage, or hardware data anywhere by default." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,14,0,0" /><TextBlock Text="GitHub: https://github.com/JGM-89/dot9" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" Margin="0,14,0,0" /><TextBlock Text="Updates: automatic updates are not implemented yet. A signed installer with update support is planned after the overlay behavior is stable." Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,14,0,0" /></StackPanel></Border></StackPanel></ScrollViewer>
        </Grid>
    </Grid>
</Window>
